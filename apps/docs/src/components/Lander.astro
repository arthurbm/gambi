---
import CopyIcon from "../assets/lander/copy.svg";
import CheckIcon from "../assets/lander/check.svg";

const commands = {
  curl: "curl -fsSL https://raw.githubusercontent.com/arthurbm/gambi/main/scripts/install.sh | bash",
  npm: "npm install -g gambi",
  bun: "bun add -g gambi",
};

const useCases = [
  {
    n: "01",
    group: "A · build with many LLMs",
    title: "Model arena",
    body: "Same prompt, every model in the room. Spot differences in tone, accuracy, and speed at a glance.",
    pattern: 'Round-robin via model:"*", N requests in parallel, render side by side.',
    href: "/guides/patterns/#model-arena",
  },
  {
    n: "02",
    group: "A · build with many LLMs",
    title: "Jury / judge panel",
    body: "Generate the answer once. Fan it out to other models for verdicts and scoring. The g-eval pattern, off the shelf.",
    pattern: "1 generator participant + N judge participants. Aggregate the votes.",
    href: "/guides/patterns/#jury-panel",
  },
  {
    n: "03",
    group: "A · build with many LLMs",
    title: "Draft → critique → polish",
    body: "Cheap-then-strong. Small model drafts, bigger one critiques, third polishes. Quality without paying frontier prices end to end.",
    pattern: "3 chained calls — output of step N feeds prompt N+1.",
    href: "/guides/patterns/#draft-critique-polish",
  },
  {
    n: "04",
    group: "B · build experiences",
    title: "Debate club",
    body: "Two models argue, a third moderates. Stream every turn through SSE for a live show.",
    pattern: "Loop between participant IDs with conflicting system prompts.",
    href: "/guides/patterns/#debate-club",
  },
  {
    n: "05",
    group: "B · build experiences",
    title: "Multi-persona NPCs",
    body: "A game where each character has its own brain. Different model, different system prompt, different attitude.",
    pattern: "One participant per persona. Route by ID at the moment of speech.",
    href: "/guides/patterns/#multi-persona-npcs",
  },
  {
    n: "06",
    group: "B · build experiences",
    title: "LAN debate club",
    body: "Bring friends or students. Each plugs their own LLM into the room. You build the UI; the models stay theirs.",
    pattern: "Multi-person registration. App reads the participant list and fans out.",
    href: "/guides/patterns/#lan-debate-club",
  },
];

const builderSpecs = [
  {
    n: "01",
    title: "Bring any provider, mix freely",
    body: "Local Ollama, vLLM, OpenRouter, OpenAI, Groq — all in the same room. Credentials and endpoints stay on the participant machine; the hub never sees them.",
    spec: "byo · tunnel · multi-source",
  },
  {
    n: "02",
    title: "Real-time observability",
    body: "Every inference emits an SSE event with TTFT, total duration, and token counts. Pipe it to a TUI, a dashboard, or your own tracer.",
    spec: "llm.request · llm.complete · llm.error",
  },
  {
    n: "03",
    title: "OpenAI-compatible everywhere",
    body: "One endpoint speaks Responses API and Chat Completions. AI SDK, OpenAI SDK, curl, any tool with a custom base URL — they all just work.",
    spec: "/responses · /chat/completions",
  },
  {
    n: "04",
    title: "Many rooms, one hub",
    body: "Run as many rooms as you want on a single hub — one per app, team, or experiment. Each room has its own participants, routing, and event stream.",
    spec: "scoped routing · isolated state",
  },
];

const providers = [
  "ollama",
  "vllm",
  "lm studio",
  "openrouter",
  "openai",
  "anthropic",
  "groq",
  "fireworks",
  "together ai",
  "localai",
];

const sdkSnippet = `import { createGambi } from "gambi-sdk";
import { generateText } from "ai";

const gambi = createGambi({
  roomCode: "ABC123",
  hubUrl: "http://localhost:3000",
});

// route to any participant
const { text } = await generateText({
  model: gambi.any(),
  prompt: "Explain TLS in one sentence.",
});

// or to a specific model
const judge = await generateText({
  model: gambi.model("claude-haiku-4-5"),
  prompt: \`Score this answer 1-10: \${text}\`,
});`;

// Evaluated once at build time (SSG) — shows deploy date, not current date.
const deployDate = new Date().toISOString().slice(0, 10);
---

<div class="lander">
  <!-- Hero — section 01 -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-frame">
      <span class="corner corner-tl" aria-hidden="true"></span>
      <span class="corner corner-tr" aria-hidden="true"></span>
      <span class="corner corner-bl" aria-hidden="true"></span>
      <span class="corner corner-br" aria-hidden="true"></span>

      <pre class="ascii-logo" aria-hidden="true">{` ██████╗  █████╗ ███╗   ███╗██████╗ ██╗
██╔════╝ ██╔══██╗████╗ ████║██╔══██╗██║
██║  ███╗███████║██╔████╔██║██████╔╝██║
██║   ██║██╔══██║██║╚██╔╝██║██╔══██╗██║
╚██████╔╝██║  ██║██║ ╚═╝ ██║██████╔╝██║
 ╚═════╝ ╚═╝  ╚═╝╚═╝     ╚═╝╚═════╝ ╚═╝`}</pre>

      <h1 id="hero-title" class="hero-title">
        <span class="hero-title-line">A shared room</span>
        <span class="hero-title-line accent">for every LLM<span class="cursor">_</span></span>
        <span class="hero-title-line">you build with.</span>
      </h1>

      <p class="hero-sub">
        Build apps where many models collaborate across people, machines and providers.
      </p>

      <p class="hero-tag">
        <span class="hero-tag-strong">Gambi ships the gateway.</span>
        <span class="hero-tag-soft">You ship the experience.</span>
      </p>

      <div class="cta-buttons">
        <a href="/guides/quickstart/" class="btn btn-primary">
          <span>Get started</span><span class="btn-arrow">↗</span>
        </a>
        <a href="/guides/patterns/" class="btn btn-secondary">See patterns</a>
        <a
          href="https://github.com/arthurbm/gambi"
          class="btn btn-secondary"
          target="_blank"
          rel="noopener"
        >GitHub</a>
      </div>

      <div class="provider-marquee" aria-hidden="true">
        <div class="provider-track">
          {[...providers, ...providers].map((p) => (
            <span class="provider-chip">
              <span class="provider-bullet">●</span>
              <span class="provider-name">{p}</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases — section 02 -->
  <section class="patterns" aria-labelledby="patterns-title">
    <header class="section-head">
      <span class="section-num">02</span>
      <span class="section-kicker">/ patterns</span>
      <h2 id="patterns-title" class="section-title">What you can build</h2>
      <p class="section-lead">
        Six recipes that fit on a few lines of TypeScript. The substrate (routing, observability, multi-source) is already there.
      </p>
    </header>

    <div class="patterns-grid">
      {useCases.map((u, i) => (
        <a class:list={["pattern-card", `card-${i}`]} href={u.href}>
          <div class="pattern-num" aria-hidden="true">{u.n}</div>
          <div class="pattern-meta" aria-hidden="true">{u.group}</div>
          <h3 class="pattern-title">{u.title}</h3>
          <p class="pattern-body">{u.body}</p>
          <p class="pattern-impl">
            <span class="impl-prefix">→ pattern:</span> {u.pattern}
          </p>
          <span class="pattern-cta">
            see pattern <span class="pattern-cta-arrow">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- How It Works — section 03 -->
  <section class="how" aria-labelledby="how-title">
    <header class="section-head">
      <span class="section-num">03</span>
      <span class="section-kicker">/ architecture</span>
      <h2 id="how-title" class="section-title">How it sits in your stack</h2>
      <p class="section-lead">
        Your app talks to a single OpenAI-compatible URL. The hub routes inside the room. Every participant runs its own provider, in its own tunnel.
      </p>
    </header>

    <div class="how-stage">
      <div class="how-col how-col-app">
        <div class="how-tag">01 · client</div>
        <div class="how-box">
          <div class="how-box-title">your app</div>
          <ul class="how-box-list">
            <li>SDK / OpenAI client / curl</li>
            <li>tool that speaks OpenAI</li>
            <li>your TUI, your dashboard</li>
          </ul>
        </div>
      </div>

      <div class="how-arrow how-arrow-1" aria-hidden="true">
        <span class="how-arrow-label">HTTP · /rooms/:code/v1</span>
        <span class="how-arrow-line"></span>
        <span class="how-arrow-tip">▶</span>
      </div>

      <div class="how-col how-col-hub">
        <div class="how-tag">02 · hub</div>
        <div class="how-box hub-box">
          <div class="how-box-title">gambi hub</div>
          <ul class="how-box-list">
            <li>room registry</li>
            <li>routing: <code>*</code> · <code>model:&lt;name&gt;</code> · <code>&lt;id&gt;</code></li>
            <li>SSE events: <code>llm.request</code> · <code>llm.complete</code></li>
          </ul>
          <div class="hub-occupancy" aria-hidden="true">
            <span class="hub-occ-label">occupancy</span>
            <span class="hub-occ-bar"><span class="hub-occ-fill"></span></span>
          </div>
        </div>
      </div>

      <div class="how-arrow how-arrow-2" aria-hidden="true">
        <span class="how-arrow-label">WS · participant tunnel</span>
        <span class="how-arrow-line"></span>
        <span class="how-arrow-tip">▶</span>
      </div>

      <div class="how-col how-col-participants">
        <div class="how-tag">03 · participants</div>
        <div class="how-box participant-box">
          <div class="how-box-title">your providers</div>
          <ul class="participant-list">
            <li><span class="dot ok"></span> ollama @ localhost:11434</li>
            <li><span class="dot ok"></span> vllm @ 192.168.1.50:8000</li>
            <li><span class="dot ok"></span> openrouter (cloud)</li>
            <li><span class="dot warn"></span> openai (rate limited)</li>
          </ul>
        </div>
      </div>
    </div>

    <p class="how-footnote">
      Provider endpoints stay on <code>localhost</code>. The hub never reaches in — the participant runtime opens the tunnel.
    </p>
  </section>

  <!-- Install + Quickstart — section 04 -->
  <section class="install" aria-labelledby="install-title">
    <header class="section-head">
      <span class="section-num">04</span>
      <span class="section-kicker">/ install</span>
      <h2 id="install-title" class="section-title">Get the room running in 60 seconds</h2>
      <p class="section-lead">
        One binary on the hub machine, one SDK call from your app. No accounts, no cloud bill, no signup.
      </p>
    </header>

    <div class="install-grid">
      <div class="install-commands">
        <div class="install-row install-row-main">
          <div class="install-tag">curl <span class="install-recommended">recommended</span></div>
          <button class="cmd" data-command={commands.curl} aria-label="copy curl install command">
            <code>
              <span class="dim">curl -fsSL</span>
              {' '}
              <span class="hi">gambi.sh/install</span>
              {' '}
              <span class="dim">| bash</span>
            </code>
            <span class="copy-icon">
              <CopyIcon />
              <CheckIcon />
            </span>
          </button>
        </div>
        <div class="install-row">
          <div class="install-tag">npm</div>
          <button class="cmd" data-command={commands.npm} aria-label="copy npm install command">
            <code><span class="dim">npm install -g</span> <span class="hi">gambi</span></code>
            <span class="copy-icon">
              <CopyIcon />
              <CheckIcon />
            </span>
          </button>
        </div>
        <div class="install-row">
          <div class="install-tag">bun</div>
          <button class="cmd" data-command={commands.bun} aria-label="copy bun install command">
            <code><span class="dim">bun add -g</span> <span class="hi">gambi</span></code>
            <span class="copy-icon">
              <CopyIcon />
              <CheckIcon />
            </span>
          </button>
        </div>

        <ol class="install-steps">
          <li><span class="step-i">i.</span> <code>gambi hub serve</code></li>
          <li><span class="step-i">ii.</span> <code>gambi room create --name "demo"</code></li>
          <li><span class="step-i">iii.</span> <code>gambi participant join --room ABC123 --model llama3</code></li>
        </ol>
      </div>

      <div class="install-snippet">
        <div class="snippet-bar">
          <span class="snippet-dot" aria-hidden="true"></span>
          <span class="snippet-dot snippet-dot-2" aria-hidden="true"></span>
          <span class="snippet-dot snippet-dot-3" aria-hidden="true"></span>
          <span class="snippet-file">app.ts · gambi-sdk</span>
        </div>
        <pre class="snippet-code"><code>{sdkSnippet}</code></pre>
      </div>
    </div>
  </section>

  <!-- Built for Builders — section 05 -->
  <section class="specs" aria-labelledby="specs-title">
    <header class="section-head">
      <span class="section-num">05</span>
      <span class="section-kicker">/ specs</span>
      <h2 id="specs-title" class="section-title">Built for builders</h2>
      <p class="section-lead">
        Going multi-model normally means re-wiring auth, routing and observability for every new provider. Gambi already did the boring parts — local-first, no signup, no cloud bill.
      </p>
    </header>

    <div class="specs-grid">
      {builderSpecs.map((s) => (
        <article class="spec-card">
          <div class="spec-head">
            <span class="spec-num">{s.n}</span>
            <h3 class="spec-title">{s.title}</h3>
          </div>
          <p class="spec-body">{s.body}</p>
          <div class="spec-detail">{s.spec}</div>
        </article>
      ))}
    </div>
  </section>

  <!-- Footer — section 06 -->
  <footer class="lander-footer">
    <div class="footer-grid">
      <div class="footer-col footer-brand">
        <div class="footer-mark">gambi</div>
        <p class="footer-tag">A room where many LLMs collaborate.</p>
      </div>

      <div class="footer-col">
        <span class="footer-label">docs</span>
        <a href="/guides/quickstart/">Quick start</a>
        <a href="/guides/patterns/">Patterns</a>
        <a href="/reference/sdk/">SDK</a>
        <a href="/reference/api/">API</a>
        <a href="/reference/cli/">CLI</a>
      </div>

      <div class="footer-col">
        <span class="footer-label">explanation</span>
        <a href="/architecture/overview/">Architecture</a>
        <a href="/explanation/tunnel-first/">How tunnels work</a>
        <a href="/explanation/why-gambi/">Why "gambi"?</a>
        <a href="/reference/observability/">Observability</a>
      </div>

      <div class="footer-col">
        <span class="footer-label">project</span>
        <a href="https://github.com/arthurbm/gambi" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.npmjs.com/package/gambi" target="_blank" rel="noopener">npm</a>
        <a href="/guides/migrate-from-gambiarra/">Migrate from gambiarra</a>
      </div>
    </div>

    <div class="footer-strip">
      <span>made with gambiarra · for the local LLM community</span>
      <span class="footer-strip-version">v0.3.x · {deployDate}</span>
    </div>
  </footer>
</div>

<style>
  /* ==========================================================================
     LANDER · "engineer's blueprint meets terminal CRT"
     ========================================================================== */

  .lander {
    --pad: clamp(1rem, 3.5vw, 2.5rem);
    --rule: 2px solid var(--gambi-border);
    --rule-strong: 2px solid var(--gambi-border-strong);
    --hairline: 1px solid var(--gambi-border);
    --grid-color: hsla(20, 10%, 35%, 0.08);

    font-family: var(--font-sans);
    background: var(--gambi-bg);
    color: var(--gambi-text);
    min-height: 100vh;

    /* dot grid background like engineer's paper */
    background-image: radial-gradient(
      var(--grid-color) 1px,
      transparent 1px
    );
    background-size: 22px 22px;
    background-position: -1px -1px;
  }

  :root[data-theme="dark"] .lander,
  :root:not([data-theme="light"]) .lander {
    --grid-color: hsla(45, 20%, 60%, 0.05);
  }

  /* --------------------------------------------------------------------------
     HERO
     -------------------------------------------------------------------------- */

  .hero {
    border-bottom: var(--rule);
    padding: clamp(1.5rem, 4vw, 3rem) var(--pad) clamp(1rem, 3vw, 2rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-frame {
    position: relative;
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(1rem, 4vw, 2.25rem) clamp(0.5rem, 3vw, 1.75rem);
  }

  /* corner brackets like architectural drawings */
  .corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: var(--gambi-accent);
  }
  .corner-tl { top: 0; left: 0; border-top: 2px solid; border-left: 2px solid; }
  .corner-tr { top: 0; right: 0; border-top: 2px solid; border-right: 2px solid; }
  .corner-bl { bottom: 0; left: 0; border-bottom: 2px solid; border-left: 2px solid; }
  .corner-br { bottom: 0; right: 0; border-bottom: 2px solid; border-right: 2px solid; }

  .ascii-logo {
    font-family: var(--font-mono);
    font-size: clamp(0.32rem, 1.05vw, 0.62rem);
    line-height: 1.2;
    color: var(--gambi-accent);
    margin: 0 auto 1.5rem;
    overflow-x: auto;
    white-space: pre;
    animation: ascii-fade 0.8s ease-out both;
    text-shadow: 0 0 12px hsla(25, 95%, 55%, 0.18);
  }

  @keyframes ascii-fade {
    from { opacity: 0; filter: blur(2px); transform: translateY(4px); }
    to { opacity: 1; filter: blur(0); transform: none; }
  }

  .hero-title {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: clamp(1.6rem, 4.4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0 auto 1.5rem;
    max-width: 40rem;
    color: var(--gambi-text);
  }

  .hero-title-line {
    display: block;
    animation: hero-line-in 0.6s ease-out both;
  }
  .hero-title-line:nth-child(1) { animation-delay: 0.05s; }
  .hero-title-line:nth-child(2) { animation-delay: 0.18s; }
  .hero-title-line:nth-child(3) { animation-delay: 0.32s; }

  @keyframes hero-line-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }

  .hero-title-line.accent {
    color: var(--gambi-accent);
  }

  .cursor {
    display: inline-block;
    color: var(--gambi-accent);
    font-weight: 400;
    margin-left: 0.05em;
    animation: cursor-blink 1.05s steps(2, start) infinite;
    transform: translateY(-0.08em);
  }

  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  .hero-sub {
    max-width: 44rem;
    margin: 0 auto 1rem;
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
    line-height: 1.55;
    color: var(--gambi-text-muted);
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--gambi-text-dimmed);
    margin: 0 0 1.75rem;
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6ch;
  }

  .hero-tag-soft::before { content: "// "; opacity: 0.6; }
  .hero-tag-strong {
    color: var(--gambi-accent-alt);
    font-weight: 600;
  }
  .hero-tag-strong::before { content: "// "; opacity: 0.6; }

  .cta-buttons {
    display: flex;
    gap: 0.65rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55ch;
    padding: 0.7rem 1.15rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    border: 2px solid transparent;
    border-radius: 0;
    transition: transform 0.12s ease, background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }

  .btn:hover {
    transform: translate(-1px, -1px);
  }

  .btn-primary {
    background: var(--gambi-accent);
    color: var(--gambi-bg);
    border-color: var(--gambi-accent);
    box-shadow: 4px 4px 0 0 var(--gambi-text);
  }
  .btn-primary:hover {
    background: var(--gambi-accent-hover);
    color: var(--gambi-bg);
    box-shadow: 6px 6px 0 0 var(--gambi-text);
  }

  .btn-secondary {
    background: var(--gambi-bg);
    color: var(--gambi-text);
    border-color: var(--gambi-border-strong);
  }
  .btn-secondary:hover {
    border-color: var(--gambi-accent);
    color: var(--gambi-accent);
    box-shadow: 4px 4px 0 0 var(--gambi-border);
  }

  .btn-arrow {
    transition: transform 0.15s ease;
  }
  .btn:hover .btn-arrow {
    transform: translate(2px, -2px);
  }

  /* provider marquee */
  .provider-marquee {
    margin-top: 0.5rem;
    padding: 0.55rem 0;
    border-top: var(--hairline);
    border-bottom: var(--hairline);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
            mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }

  .provider-track {
    display: flex;
    gap: 2.5rem;
    width: max-content;
    animation: marquee 38s linear infinite;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .provider-chip {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--gambi-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-flex;
    align-items: center;
    gap: 0.6ch;
  }

  .provider-bullet {
    color: var(--gambi-accent-alt);
  }

  .provider-name::before { content: "// "; opacity: 0.5; }

  /* --------------------------------------------------------------------------
     SECTION HEAD — shared across patterns/how/install/specs
     -------------------------------------------------------------------------- */

  .section-head {
    padding: 1.25rem var(--pad) 1.25rem;
    border-bottom: var(--rule);
    display: grid;
    grid-template-columns: auto auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.25rem 0.75rem;
    align-items: baseline;
  }

  .section-num {
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--gambi-accent);
    background: var(--gambi-bg-alt);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--gambi-accent);
