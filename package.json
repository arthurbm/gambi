{
  "name": "gambi",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd packages/cli dev -- hub serve",
    "dev:hub": "bun run --cwd packages/cli dev -- hub serve",
    "dev:cli": "bun run --cwd packages/cli dev --",
    "dev:tui": "bun run --cwd apps/tui src/index.tsx",
    "dev:monitor": "bun run --cwd apps/tui dev",
    "dev:docs": "turbo -F docs dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "clean-deps": "bun run scripts/clean-deps.ts"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@gambi/config": "workspace:*",
    "turbo": "^2.6.3",
    "typescript": "^5",
    "ultracite": "7.0.7"
  },
  "packageManager": "bun@1.3.13"
}
